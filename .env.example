# Discord通知
DISCORD_WEBHOOK_URL=

# GCP設定（Terraform経由で設定済み。ローカル実行時のみ必要）
GCP_PROJECT=mlops-dev-a
GCS_BUCKET=mlops-dev-a-doc-qa
BQ_DATASET=doc_qa_dataset
BQ_TABLE=documents

# Elastic Cloud（Secret Manager経由で取得。ローカルテスト時のみ直接設定）
# ES_SECRET_NAME=elastic-cloud-api-key
# ELASTIC_CLOUD_URL=
# ELASTIC_API_KEY=

# Elasticsearch インデックス名
ES_INDEX=doc-qa

# ==================================================
# 設定・シークレット管理
# ==================================================
#
# env/config/application.yml        ← プロジェクト固有設定（非シークレット）
# env/secret/credentials.json       ← 全クレデンシャル統合（GCP SA + Elastic Cloud）
# terraform/terraform.tfvars        ← Terraform 変数（Elastic Cloud APIキー）
#
# credentials.json の構造:
#   {
#     "gcp_service_account": { ... },          ← GCP SA キー
#     "elastic_cloud": {
#       "cloud_api_key": "...",                ← ec プロバイダ認証用
#       "api_key": "...",                      ← ES接続用
#       "cloud_url": "https://..."             ← ES Cloud URL
#     }
#   }
#
# CI/CD（GitHub Actions）:
#   GCP_SA_KEY, ELASTIC_CLOUD_API_KEY, ELASTIC_API_KEY を
#   GitHub Secrets に設定。TF_VAR_ 環境変数で渡す。
